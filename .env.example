# ============================================================
# DS Akademi - Environment Variables
# Bu dosyayı .env.local (geliştirme) veya Dokploy env paneline kopyalayın
# ============================================================

# ============================================================
# VERİTABANI
# ============================================================

# Dokploy'da PostgreSQL servisi oluşturduktan sonra bu URL'yi alırsınız.
# Format: postgresql://KULLANICI:SIFRE@HOST:PORT/VERITABANI
# Dokploy iç ağ için: postgresql://ds_user:SIFRE@postgres:5432/ds_akademi
# Supabase'den geçiş için: Supabase > Settings > Database > Connection string (URI)
DATABASE_URL=postgresql://ds_user:changeme123@localhost:5432/ds_akademi

# ============================================================
# NEXTAUTH / AUTH.JS
# ============================================================

# Güçlü bir secret üretin: openssl rand -base64 32
AUTH_SECRET=BURAYA_GUCLU_BIR_SECRET_GIRIN

# Uygulamanızın tam URL'si (trailing slash olmadan)
# Dokploy'da domain atadıktan sonra güncelleyin
NEXTAUTH_URL=https://yourdomain.com

# Reverse proxy (Nginx/Traefik) arkasında çalışmak için zorunlu
AUTH_TRUST_HOST=true

# ============================================================
# UYGULAMA
# ============================================================

NODE_ENV=production

# ============================================================
# NOTLAR
# ============================================================
# 1. AUTH_SECRET için: openssl rand -base64 32
# 2. Dokploy'da PostgreSQL servisi oluşturun, internal connection string'i kullanın
# 3. NEXTAUTH_URL'yi Dokploy'da atadığınız domain ile güncelleyin
# 4. AUTH_TRUST_HOST=true Dokploy/Nginx/Traefik reverse proxy için zorunludur
